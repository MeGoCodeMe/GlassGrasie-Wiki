const USERS: Record<string, string> = {
  'gertjan@glassgrasie.com': 'xdefNbWnJsmchi0y'
};

const STYLES = {
  dark: { bg: '#0a0a0a', textPrimary: '#eeeeee', textSecondary: '#aaaaaa', textTertiary: '#cccccc', gold: '#c9a87c', goldHover: '#b8965c', cardBg: 'rgba(10,10,10,0.7)', inputBg: '#333333' },
  light: { bg: '#f5f5f5', textPrimary: '#1a1a1a', textSecondary: '#666666', textTertiary: '#999999', gold: '#b8965c', goldHover: '#9d7e4a', cardBg: '#ffffff', inputBg: '#f0f0f0' }
};

const STYLE = {
  fontFamily: "'Cormorant Garamond', Georgia, serif",
  ...STYLES.dark
};

function parseMarkdown(md: string): string {
  let html = md
    .replace(/^### (.*?)$/gm, '<h3>$1</h3>')
    .replace(/^## (.*?)$/gm, '<h2>$1</h2>')
    .replace(/^# (.*?)$/gm, '<h1>$1</h1>')
    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
    .replace(/__(.*?)__/g, '<strong>$1</strong>')
    .replace(/\*(.*?)\*/g, '<em>$1</em>')
    .replace(/_(.*?)_/g, '<em>$1</em>')
    .replace(/\`\`\`[\s\S]*?\`\`\`/g, (match) => '<pre><code>' + match.replace(/\`\`\`/g, '') + '</code></pre>')
    .replace(/\`(.*?)\`/g, '<code>$1</code>')
    .replace(/\[(.*?)\]\((.*?)\)/g, '<a href="/wiki?note=$2">$1</a>')
    .replace(/\n\n+/g, '</p><p>')
    .replace(/\n/g, '<br>');
  return '<p>' + html + '</p>';
}

function extractBacklinks(md: string): string[] {
  const regex = /\[(.*?)\]\((.*?)\)/g;
  const links: string[] = [];
  let match;
  while ((match = regex.exec(md)) !== null) {
    const fileName = match[2].replace('.md', '');
    if (NOTES.find(n => n.toLowerCase().includes(fileName.toLowerCase()))) {
      links.push(match[2]);
    }
  }
  return links;
}

async function getNoteMeta(filename: string, env: WikiEnv): Promise<{ lastModified: string } | null> {
  const url = 'https://api.github.com/repos/' + env.GITHUB_OWNER + '/' + env.GITHUB_REPO + '/commits?path=notes/' + encodeURIComponent(filename) + '&per_page=1';
  try {
    const res = await fetch(url);
    if (res.ok) {
      const data: any[] = await res.json();
      if (data.length > 0) {
        const date = new Date(data[0].commit.committer.date);
        return { lastModified: date.toLocaleDateString('nl-NL', { year: 'numeric', month: 'long', day: 'numeric' }) };
      }
    }
    return null;
  } catch (e) {
    console.error('Meta fetch error: ' + e);
    return null;
  }
}

function generateInviteToken(): string {
  return Array.from(crypto.getRandomValues(new Uint8Array(12))).map(b => b.toString(16).padStart(2, '0')).join('');
}

